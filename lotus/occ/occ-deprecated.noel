      (cl-defmethod occ-do-clock-in ((ctx occ-ctx))
        "marker and ranked version"
        (interactive
         (list (occ-obj-make-ctx-at-point)))
        (progn
          (occ-debug "in occ-do-clock-in occ-ctx 1")
          (let* ((ctx (or ctx (occ-obj-make-ctx-at-point)))
                 (matched-ctxual-tsks
                  (occ-run-unobtrusively           ;heavy task

                    ;; BUG Urgent TODO: SOLVE ASAP ???? at (occ-do-clock-in-if-not ctx) and (occ-do-clock-in ctx)

                    ;; begin occ-do-clock-in-curr-ctx-if-not
                    ;; 2019-03-06 22:55:31 s: occ-do-clock-in-curr-ctx-if-not: lotus-with-other-frame-event-debug
                    ;; occ-do-clock-in-if-not: Now really going to clock.
                    ;; in occ-do-clock-in occ-ctx 1
                    ;; user input 111 retval t
                    ;; trying to create unnamed tsk.
                    ;; occ-maybe-create-unnamed-tsk: Already clockin unnamed tsk
                    ;; occ-do-clock-in-if-not: Now really clock done.

                    (remove-if-not
                     #'(lambda (ctxual-tsk)
                         (let* ((marker (occ-ctxual-tsk-marker ctxual-tsk)))
                           (and
                            marker
                            (marker-buffer marker))))
                     (occ-matching-ctxual-tsks (occ-obj-collection-object) ctx)))))
            (unless (eq matched-ctxual-tsks t)
              (if matched-ctxual-tsks
                  (let* ((sel-ctxual-tsk
                          (if (> (length matched-ctxual-tsks) 1)
                              (occ-sacha-helm-select-timed matched-ctxual-tsks)
                            (first matched-ctxual-tsks))))
                    ;; (sel-tsk   (if sel-ctxual-tsk (plist-get sel-ctxual-tsk :tsk)))
                    ;; (sel-marker (if sel-tsk      (plist-get sel-tsk      :tsk-clock-marker)))

                    ;; (occ-debug "sel-ctxual-tsk %s sel-tsk %s sel-marker %s" sel-ctxual-tsk sel-tsk sel-marker)
                    (if sel-ctxual-tsk (occ-do-clock-in sel-ctxual-tsk)))
                (progn
                  ;; here create unnamed tsk, no need
                  (setq *occ-update-current-ctx-msg* "null clock")
                  (occ-debug
                             "No clock found please set a match for this ctx %s, add it using M-x occ-do-add-to-org-heading."
                             ctx)
                  (occ-do-add-to-org-heading-when-idle ctx 7)
                  nil))))))

      (cl-defmethod occ-do-clock-in ((new-ctxask occ-ctxual-tsk))
        ;;TODO add org-insert-log-not
        (occ-debug "occ-do-clock-in-marker %s" new-ctxask)
        (let* (retval
               (old-ctxual-tsk     (first *occ-clocked-ctxual-tsk-ctx-history*))
               (old-tsk            (when old-ctxual-tsk (occ-ctxual-tsk-tsk old-ctxual-tsk)))
               (old-marker         (or (if old-tsk (occ-tsk-marker old-tsk)) org-clock-hd-marker))
               (old-heading        (if old-tsk (occ-tsk-heading old-tsk)))
               (new-tsk            (occ-ctxual-tsk-tsk new-ctxask))
               (new-marker         (if new-tsk (occ-tsk-marker new-tsk)))
               (new-heading        (if new-tsk (occ-tsk-heading new-tsk))))
          (when (and
                 new-marker
                 (marker-buffer new-marker))

            (let* ((org-log-note-clock-out nil)
                   (old-marker org-clock-marker)
                   (old-buff   (marker-buffer old-marker)))

              (occ-debug "clocking in %s" new-marker)

              (let ((old-buff-read-only
                     (if old-buff
                         (with-current-buffer (marker-buffer old-marker)
                           buffer-read-only))))

                (if old-buff
                    (with-current-buffer old-buff
                      (setq buffer-read-only nil)))

                (setq *occ-update-current-ctx-msg* old-marker)

                (run-hook-with-args 'occ-do-clock-in-hooks
                                    old-marker
                                    new-marker)

                (when (and
                       new-heading
                       old-marker
                       (marker-buffer old-marker))
                  (org-insert-log-note old-marker (format "clocking out to clockin to <%s>" new-heading)))

                (with-current-buffer (marker-buffer new-marker)
                  (let ((buffer-read-only nil))
                    (when old-heading
                      (org-insert-log-note new-marker (format "clocking in to here from last clock <%s>" old-heading)))
                    (condition-case-control err
                      (progn
                        (occ-straight-org-clock-clock-in (list new-marker))
                        (setq retval t)
                        (push new-ctxask *occ-clocked-ctxual-tsk-ctx-history*))
                      ((occ-error)
                       (progn
                         (setq retval nil)
                         (signal (first err) (rest err)))))))

                (if old-buff
                    (with-current-buffer old-buff
                      (setq buffer-read-only old-buff-read-only)))
                retval)))))






      (cl-defgeneric occ-obj-sacha-selection-line (obj))


      (cl-defmethod occ-obj-sacha-selection-line ((mrk marker))
        "Insert a line for the clock selection menu.
      And return a cons cell with the selection character integer and the mrk
      pointing to it."
        (when (mrk-buffer mrk)
          (with-current-buffer (org-base-buffer (mrk-buffer mrk))
            (org-with-wide-buffer
             (progn ;; ignore-errors
               (goto-char mrk)
               (let* ((cat (org-get-category))
                      (heading (org-get-heading 'notags))
                      (prefix (save-excursion
                                (org-back-to-heading t)
                                (looking-at org-outline-regexp)
                                (match-string 0)))
                      (tsk (substring
                            (org-fontify-like-in-org-mode
                             (concat prefix heading)
                             org-odd-levels-only)
                            (length prefix))))
                 (when tsk ;; (and cat tsk)
                   ;; (insert (format "[%c] %-12s  %s\n" i cat tsk))
                   ;; mrk
                   (cons tsk mrk))))))))

      (cl-defmethod occ-obj-sacha-selection-line ((tsk occ-tsk))
        "Insert a line for the clock selection menu.
      And return a cons cell with the selection character integer and the marker
      pointing to it."
        (cons (occ-print tsk) tsk))

      (cl-defmethod occ-obj-sacha-selection-line ((ctxask occ-ctxual-tsk))
        "Insert a line for the clock selection menu.
      And return a cons cell with the selection character integer and the marker
      pointing to it."
        (cons (occ-print ctxask) ctxask))

      (defun occ-sacha-helm-select (ctxasks)
        ;; (occ-debug "sacha marker %s" (first dyntskpls))
        (occ-debug "Running occ-sacha-helm-select")
        (helm
         (list
          (helm-build-sync-source "Select matching tsks"
            :candidates (mapcar 'occ-obj-sacha-selection-line ctxasks)
            :action (list ;; (cons "Select" 'identity)
                     (cons "Clock in and track" #'identity))
            :history 'org-refile-history))))
      ;; (helm-build-dummy-source "Create tsk"
      ;;   :action (helm-make-actions
      ;;            "Create tsk"
      ;;            'sacha/helm-org-create-tsk))


      (defun occ-sacha-helm-select-timed (ctxasks)
        (helm-timed occ-idle-timeout nil
          (occ-debug "running sacha/helm-select-clock")
          (occ-sacha-helm-select ctxasks))))



    (cl-defgeneric occ-obj-sacha-helm-action (ctxask clockin-fn)
      "occ-obj-sacha-helm-action")

    (cl-defmethod occ-obj-sacha-helm-action ((ctxask occ-ctxual-tsk) clockin-fn)
      ;; (occ-debug "sacha marker %s" (first dyntskpls))
      ;; (setq sacha/helm-org-refile-locations tbl)
      (progn
        (helm
         (list
          (helm-build-sync-source "Select matching tsks"
            :candidates (mapcar 'occ-obj-sacha-selection-line ctxask)
            :action (list ;; (cons "Select" 'identity)
                     (cons "Clock in and track" #'(lambda (c) (funcall clockin-fn c))))
            :history 'org-refile-history)))))
