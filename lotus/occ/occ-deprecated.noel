(require 'occ-obj-method)
(require 'occ-prop)


(defun occ-org-set-property (prop value)
  (lotus-org-with-safe-modification
    (org-set-property prop value)))
(cl-defmethod occ-obj-readprop ((prop symbol) (ctx occ-ctx))
  (occ-debug "occ-obj-readprop: prop: %s" prop)
  (occ-obj-readprop (cons prop (occ-obj-make-tsk nil)) ctx))
(cl-defmethod occ-obj-writeprop ((prop symbol) value)
  (occ-debug "occ-obj-writeprop: prop: %s, value: %s" prop value)
  (if value
      (progn
        (unless (org-get-property-block)
          ;;create property drawer
          (occ-debug "occ-obj-writeprop: property block not exist so creating it.")
          (let* ((range (org-get-property-block (point) 'force))
                 (start (when (consp range) (1- (first range)))))
            (when (numberp start)
              (goto-char start))))
        (occ-debug "occ-obj-writeprop: adding prop: %s value: %s using (org-set-property)." prop value)
        (occ-org-set-property (symbol-name prop) value))
    (occ-error "occ-obj-writeprop value is nil")))
(cl-defmethod occ-do-editprop ((prop symbol) (ctx occ-ctx))
  (let ((value (occ-obj-readprop prop ctx)))
    (occ-debug "occ-do-editprop: prop: %s, value: %s" prop value)
    (occ-obj-writeprop prop value)))







(defun occ-org-set-property (prop value)
  (lotus-org-with-safe-modification
    (org-set-property prop value)))

(cl-defgeneric occ-obj-writeprop-with (prop
                                   obj
                                   ctx
                                   value)
  "occ-obj-writeprop-with")
(cl-defgeneric occ-obj-readprop-with (prop
                                  obj
                                  ctx)
  "occ-obj-readprop-with")
(cl-defmethod occ-do-editprop-with (prop
                                 obj
                                 ctx)
  "occ-do-editprop-with")

(cl-defgeneric occ-obj-writeprop (prop
                              obj
                              value)
  "occ-obj-writeprop")
(cl-defgeneric occ-obj-readprop (prop
                             obj)
  "occ-obj-readprop")
(cl-defmethod occ-do-editprop (prop
                            obj)
  "occ-do-editprop")



(cl-defmethod occ-obj-writeprop-with ((prop symbol)
                                  (obj occ-tsk)
                                  (ctx occ-ctx)
                                  value)
  (occ-debug "occ-obj-writeprop: prop: %s, value: %s"
             prop value)
  (if value
      (progn
        (unless (org-get-property-block)
          ;;create property drawer
          (occ-debug "occ-obj-writeprop: property block not exist so creating it.")
          (let* ((range (org-get-property-block (point) 'force))
                 (start (when (consp range) (1- (first range)))))
            (when (numberp start)
              (goto-char start))))
        (occ-debug
                   "occ-obj-writeprop: adding prop: %s value: %s using (org-set-property)." prop value)
        (occ-org-set-property (symbol-name prop) value))
    (occ-error "occ-obj-writeprop value is nil")))
(cl-defmethod occ-obj-readprop-with ((prop symbol)
                                 (obj occ-tsk)
                                 (ctx occ-ctx))
  (occ-debug "occ-obj-readprop: prop: %s"
             prop)
  (occ-obj-readprop prop obj ctx))
(cl-defmethod occ-do-editprop-with ((prop symbol)
                                 (obj occ-tsk)
                                 (ctx occ-ctx))
  (let ((value (occ-obj-readprop prop obj ctx)))
    (occ-debug
               "occ-do-editprop: prop: %s, value: %s" prop value)
    (occ-obj-writeprop-with prop obj ctx value)))


(cl-defmethod occ-obj-writeprop ((prop symbol)
                             (obj occ-obj-ctx-tsk)
                             value)
  (occ-debug "occ-obj-writeprop: prop: %s, value: %s"
             prop value)
  (let ((tsk (occ-ctsk-tsk obj))
        (ctx (occ-ctsk-ctx obj)))
    (occ-obj-writeprop-with prop tsk ctx value)))
(cl-defmethod occ-obj-readprop ((prop symbol)
                            (obj occ-obj-ctx-tsk))
  (occ-debug "occ-obj-readprop: prop: %s"
             prop)
  (let ((tsk (occ-ctsk-tsk obj))
        (ctx (occ-ctsk-ctx obj)))
    (occ-obj-readprop-with prop tsk ctx)))
(cl-defmethod occ-do-editprop ((prop symbol)
                            (obj occ-obj-ctx-tsk))
  (let ((value (occ-obj-readprop prop obj)))
    (occ-debug
               "occ-do-editprop: prop: %s, value: %s" prop value)
    (occ-obj-writeprop prop obj value)))












































;;{{ file
(when nil                               ;rank calculation for org file name in which tsk aka entry not much useful
  (cl-defmethod occ-obj-rank ((tsk-pair (head file))
                          (ctx occ-ctx))
   ;; file in which tsk aka org entry exists.
   "Predicate funtion to check if ctx matches to tsk's file attribute."
   (let ((prop (first tsk-pair))
         (tsk  (rest tsk-pair)))
     (let* ((currfile (occ-obj-get-property tsk 'currfile))
            (currfile (if currfile (file-truename currfile))))
      (let* ((file (occ-ctx-file ctx))
             (file (if file (file-truename file))))
        (if currfile
            (progn
              (occ-nodisplay "tsk %s currfile %s" (occ-tsk-heading tsk) currfile)
              (occ-nodisplay "tsk %s file %s"     (occ-tsk-heading tsk) file))
          (occ-nodisplay "tsk %s currfile %s not present."
                     (occ-tsk-heading tsk) currfile))
        (if (and currfile file
                 (string-match currfile file))
            (* 2 (length currfile))     ;as exact match to file giving double matching points.
          0))))))
;;}}

;;{{ currfile
(cl-defmethod occ-obj-rank ((tsk-pair (head currfile))
                        (ctx occ-ctx))
  ;; file in which tsk aka org entry exists.
  "Predicate funtion to check if ctx matches to tsk's file attribute."
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let* ((currfile (occ-obj-get-property tsk 'currfile))
           (currfile (if currfile (file-truename currfile))))
      (let* ((file (occ-ctx-file ctx))
             (file (if file (file-truename file))))
        (if currfile
            (progn
              (occ-nodisplay "tsk %s currfile %s" (occ-tsk-heading tsk) currfile)
              (occ-nodisplay "tsk %s file %s"     (occ-tsk-heading tsk) file))
          (occ-nodisplay "tsk %s currfile %s not present."
                     (occ-tsk-heading tsk) currfile))
        (if (and currfile file
                 (string-match currfile file))
            (* 2 (length currfile))     ;as exact match to file giving double matching points.
          0)))))

(cl-defmethod occ-obj-ctx-property-get ((ctx-pair (head currfile)))
  "file of context"
  (let* ((ctx (rest ctx-pair))
         (currfile (occ-ctx-file ctx)))
    currfile))
(cl-defmethod occ-obj-readprop ((tsk-pair (head currfile))
                            (ctx occ-ctx))
  "currfile property for tsk aka org entry"
  (let* ((currfile (if ctx (occ-ctx-file ctx)))
         (dir (when (stringp currfile)
                  (file-name-directory currfile) (dirname-of-file currfile)))
         (prompt (concat (symbol-name (first tsk-pair)) ": ")))
    (ido-read-currfile-name prompt dir currfile)))
;;}}

;;{{ root
(cl-defmethod occ-obj-rank ((tsk-pair (head root))
                        (ctx occ-ctx))
  "Predicate funtion to check if ctx matches to tsk's file attribute."
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let* ((root (occ-obj-get-property tsk 'root))
           (root (if root (file-truename root))))
     (let* ((file (occ-ctx-file ctx))
            (file (if file (file-truename file))))
       (if root
           (progn
             (occ-nodisplay "tsk %s root %s" (occ-tsk-heading tsk) root)
             (occ-nodisplay "tsk %s file %s" (occ-tsk-heading tsk) file))
         (occ-nodisplay "tsk %s root %s not present."
                    (occ-tsk-heading tsk) root))
       (if (and root file
                (string-match root file))
           (length root)
         0)))))
(cl-defmethod occ-obj-ctx-property-get ((ctx-pair (head root)))
  (let* ((ctx (rest ctx-pair))
         (file (occ-ctx-file ctx))
         (root (and file (dirname-of-file file))))
    root))
(cl-defmethod occ-obj-readprop ((tsk-pair (head root))
                            (ctx occ-ctx))
  (let* ((file (if ctx (occ-ctx-file ctx)))
         (dir (if (stringp file) (file-name-directory file) (dirname-of-file file)))
         (prompt (concat (symbol-name (first tsk-pair)) ": ")))
    (ido-read-directory-name prompt dir dir)))
;;}}

;;{{ sub-tree
(cl-defmethod occ-obj-readprop ((tsk-pair (head subtree))
                            (ctx occ-ctx))
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let ((prompt (concat (symbol-name (first tsk-pair)) ": ")))
     (file-relative-name
       (ido-read-file-name ;; org-iread-file-name
        prompt
        default-directory default-directory)))))

(cl-defmethod occ-obj-writeprop ((tsk-pair (head subtree)) value))
;;}}

;;{{ git-branch
(cl-defmethod occ-obj-ctx-property-get ((ctx-pair (head git-branch)))
  (let* ((ctx (rest ctx-pair))
         (file (occ-ctx-file ctx)))
    file))
;;}}

;;{{ git-branch
;;}}

;;{{ git-branch
;;}}

;;{{ git-branch
;;}}






(cl-defmethod occ-obj-rank ((tsk-pair (head status))
                        (ctx occ-ctx))
  "Predicate funtion to check if ctx matches to tsk's status attribute."
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let ((todo-type
           (occ-obj-get-property tsk 'todo-type))
          (closed
           (occ-obj-get-property tsk 'closed))
          (status
           (occ-obj-get-property tsk 'todo-keyword)))
      (if (or
           closed
           (eql todo-type 'done)
           (string= status "HOLD"))
          -30 0))))

(cl-defmethod occ-obj-rank ((tsk-pair (head key))
                        (ctx occ-ctx))
  "Predicate funtion to check if ctx matches to tsk's file attribute."
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let* ((key (occ-obj-get-property tsk 'KEY)))
      (if key (string-to-number key) 0))))

(cl-defmethod occ-obj-rank ((tsk-pair (head heading-level))
                        (ctx occ-ctx))
  "Predicate funtion to check if ctx matches to tsk's file attribute."
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let* ((level (occ-obj-get-property tsk 'level)))
      (if level level 0))))

(cl-defmethod occ-obj-rank ((tsk-pair (head timebeing))
                        (ctx occ-ctx))
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
   (let ((timebeing (occ-obj-get-property tsk 'timebeing)))
     (let ((timebeing-time (if timebeing (org-duration-string-to-minutes timebeing) 0))
           (clocked-time   (occ-obj-get-property tsk 'clock-sum)))
       (if (and
            (numberp clocked-time)
            (numberp timebeing-time)
            (> timebeing-time clocked-time))
           (- timebeing-time clocked-time)
         0)))))

(cl-defmethod occ-obj-rank ((tsk-pair (head current-clock))
                        (ctx occ-ctx))
  (let ((prop (first tsk-pair))
        (tsk  (rest tsk-pair)))
    (let* ((tsk-marker (occ-obj-get-property tsk 'marker)))
      (if (and
           (markerp org-clock-hd-marker)
           (markerp tsk-marker)
           (equal org-clock-hd-marker org-clock-hd-marker))
          100
        0))))


(when nil
  (occ-cl-method-first-arg 'occ-obj-ctx-property-get)
  (occ-obj-readprop-props)
  (occ-obj-cl-method-matched-arg 'occ-obj-readprop 'occ-obj-ctx-property-get (occ-obj-make-ctx-at-point))
  (funcall 'occ-obj-ctx-property-get (cons 'file (occ-obj-make-ctx-at-point))))

(when nil
  (occ-obj-cl-method-sigs-matched-arg '(occ-obj-readprop (`((head ,val) occ-ctx) val))
   '(occ-obj-ctx-property-get (`((head ,val) val)))
   (occ-obj-make-ctx-at-point)))



(defun occ-obj-readprop-props ()
  (occ-cl-method-param-case
   '(occ-obj-readprop (`((head ,val) occ-ctx) val))))



